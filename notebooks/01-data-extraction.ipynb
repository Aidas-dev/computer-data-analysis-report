    "source": [
     "## Federal Reserve Economic Data (fredapi)",
     "",
     "Fetches GDP, inflation, interest rates, and other macroeconomic indicators.",
     "",
     "**API Key Required:** Sign up at https://fred.stlouisfed.org/fredapi/"
    ]
   },
   {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
     "# Fetch Federal Reserve economic data",
     "import os",
     "",
     "# Get FRED API key from environment or Colab secrets",
     "FRED_API_KEY = os.environ.get(\"FRED_API_KEY\")",
     "",
     "# Also check Colab secrets if available",
     "if not FRED_API_KEY and IS_COLAB:",
     "    try:",
     "        from google.colab import userdata",
     "        FRED_API_KEY = userdata.get(\"FRED_API_KEY\")",
     "    except:",
     "        pass",
     "",
     "if FRED_API_KEY:",
     "    from fredapi import fred",
     "    ",
     "    "fred = fred.FRED(api_key=FRED_API_KEY)",
     "    ",
     "    # Key economic indicators",
     "    series_ids = {",
     "        \"GDPC1\": \"Real GDP\",",
     "        \"CPILFESL\": \"Inflation (Core CPI)\",",
     "        \"FEDFUNDS\": \"Fed Funds Rate\",",
     "        \"UNRATE\": \"Unemployment Rate\",",
     "        \"MORTGAGE30US\": \"30-Year Mortgage Rate\",",
     "    }",
     "    ",
     "    "fred_dfs = {}",
     "    "print(\"\ud83d\udcc9 Fetching FRED economic data...\")",
     "    for series_id, name in series_ids.items():",
     "        try:",
     "            df = fred.get_series_all_releases(series_id)",
     "            df = df.rename(columns={\"value\": name})",
     "            df = df[[\"date\", name]]",
     "            fred_dfs[series_id] = df",
     "            print(f\"  \u2705 {series_id}: {len(df)} observations\")",
     "        except Exception as e:",
     "            print(f\"  \u274c {series_id}: {str(e)[:30]}\")",
     "    ",
     "    "if fred_dfs:",
     "        # Merge all series by date",
     "        fred_combined = None",
     "        import functools as ft",
     "        fred_combined = ft.reduce(lambda x, y: x.merge(y, on=\"date\", how=\"outer\"), fred_dfs.values())",
     "        fred_combined = fred_combined.sort_values(\"date\").reset_index(drop=True)",
     "        print(f\"\u2705 Combined FRED data: {len(fred_combined)} rows\")",
     "        display(fred_combined.head())",
     "        ",
     "        # Store in DVC",
     "        store_dataframes_in_dvc(data=fred_combined, names=\"fred_economic_indicators\", folder_type=\"raw\")",
     "else:",
     "    print(\"\u26a0\ufe0f FRED API key required!\")",
     "    print(\"Sign up at: https://fred.stlouisfed.org/fredapi/\")",
     "    print(\"Add to Colab Secrets as FRED_API_KEY\")"
    ]
   }
