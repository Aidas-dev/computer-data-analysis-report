    "# Yahoo Finance Data Extraction & DVC Tracking\n",
    "\n",
    "This notebook demonstrates how to fetch data using `yfinance` and then use our custom `src/data/dvc_storage.py` module to store the resulting DataFrames securely in the Oracle Cloud DVC remote.\n",
    "\n",
    "**Prerequisite:** Make sure you have successfully authenticated with Oracle via DVC (run `00-colab-setup.ipynb` if you are in Colab)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import sys\n",
    "import os\n",
    "\n",
    "# Ensure the 'src' directory is accessible for imports\n",
    "sys.path.append(os.path.abspath('..'))\n",
    "\n",
    "from src.data.dvc_storage import store_dataframes_in_dvc"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# AI Data Center Dataset Extraction\n",
    "\n",
    "This notebook extracts data from yfinance and gridstatus APIs to build a unified dataset for analyzing AI data center buildout promises.\n",
    "\n",
    "## Data Sources\n",
    "- **yfinance**: Company financials for data center REITs and hyperscalers\n",
    "- **gridstatus**: US power grid interconnection queues\n",
    "- **Target**: Whether buildout promises were kept\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Configuration: AI Data Center Company Tickers\n",
    "COMPANY_TICKERS = {\n",
    "    # Data Center REITs\n",
    "    \"DLR\": \"Digital Realty Trust\",\n",
    "    \"EQIX\": \"Equinix\",\n",
    "    \"AMT\": \"American Tower\",\n",
    "    # Hyperscalers\n",
    "    \"MSFT\": \"Microsoft\",\n",
    "    \"GOOGL\": \"Alphabet (Google)\",\n",
    "    \"AMZN\": \"Amazon\",\n",
    "    \"META\": \"Meta Platforms\",\n",
    "    # GPU/AI Infrastructure\n",
    "    \"NVDA\": \"NVIDIA\",\n",
    "}\n",
    "\n",
    "# Grid ISOs to fetch\n",
    "GRID_ISOS = [\"CAISO\", \"MISO\", \"ERCOT\", \"PJM\", \"SPP\", \"NYISO\"]\n",
    "\n",
    "print(f\"\ud83d\udcca Configured {len(COMPANY_TICKERS)} companies and {len(GRID_ISOS)} grid ISOs\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fetch company historical data from yfinance\n",
    "import yfinance as yf\n",
    "\n",
    "company_dfs = {}\n",
    "\n",
    "print(\"\ud83d\udcc8 Fetching company data from yfinance...\\n\")\n",
    "for ticker, name in COMPANY_TICKERS.items():\n",
    "    try:\n",
    "        # Get history (OHLCV)\n",
    "        ticker_obj = yf.Ticker(ticker)\n",
    "        history = ticker_obj.history(period=\"2y\")\n",
    "        info = ticker_obj.info\n",
    "        \n",
    "        if not history.empty:\n",
    "            # Add company metadata columns\n",
    "            history = history.copy()\n",
    "            history[\"ticker\"] = ticker\n",
    "            history[\"company_name\"] = name\n",
    "            history[\"market_cap\"] = info.get(\"marketCap\")\n",
    "            history[\"revenue\"] = info.get(\"totalRevenue\")\n",
    "            history[\"peg_ratio\"] = info.get(\"pegRatio\")\n",
    "            history[\"debt_to_equity\"] = info.get(\"debtToEquity\")\n",
    "            company_dfs[ticker] = history\n",
    "            print(f\"  \u2705 {ticker}: {len(history)} rows, last date {history.index[-1].strftime('%Y-%m-%d')}\")\n",
    "        else:\n",
    "            print(f\"  \u26a0\ufe0f {ticker}: No data returned\")\n",
    "    except Exception as e:\n",
    "        print(f\"  \u274c {ticker}: {str(e)[:50]}\")\n",
    "\n",
    "# Combine all company data\n",
    "company_combined = pd.concat(company_dfs.values(), ignore_index=False)\n",
    "print(f\"\\n\ud83d\udcca Combined company data: {len(company_combined)} total rows\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fetch grid interconnection queue data from gridstatus\n",
    "import gridstatus\n",
    "\n",
    "queue_dfs = {}\n",
    "\n",
    "print(\"\u26a1 Fetching grid interconnection queues...\\n\")\n",
    "for iso_name in GRID_ISOS:\n",
    "    try:\n",
    "        iso = gridstatus.get_iso(iso_name.lower())\n",
    "        queue = iso.get_queue()\n",
    "        \n",
    "        if queue is not None and len(queue) > 0:\n",
    "            queue[\"iso\"] = iso_name\n",
    "            # Select relevant columns if they exist\n",
    "            cols_to_keep = [\"iso\"]\n",
    "            for col in [\"project_name\", \"capacity_mw\", \"status\", \"queue_date\", \"requested_date\", \"interconnecting_entity\"]:\n",
    "                if col in queue.columns:\n",
    "                    cols_to_keep.append(col)\n",
    "            queue = queue[[c for c in cols_to_keep if c in queue.columns]]\n",
    "            queue_dfs[iso_name] = queue\n",
    "            print(f\"  \u2705 {iso_name}: {len(queue)} projects in queue\")\n",
    "        else:\n",
    "            print(f\"  \u26a0\ufe0f {iso_name}: No queue data available\")\n",
    "    except Exception as e:\n",
    "        print(f\"  \u274c {iso_name}: {str(e)[:50]}\")\n",
    "\n",
    "# Combine all queue data\n",
    "if queue_dfs:\n",
    "    queue_combined = pd.concat(queue_dfs.values(), ignore_index=True)\n",
    "    print(f\"\\n\u26a1 Combined grid queue: {len(queue_combined)} total projects\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save unified datasets to DVC\n",
    "from src.data.dvc_storage import store_dataframes_in_dvc\n",
    "\n",
    "# 1. Save company financial data\n",
    "if \"company_combined\" in dir() and not company_combined.empty:\n",
    "    store_dataframes_in_dvc(\n",
    "        data=company_combined, \n",
    "        names=\"company_financials\", \n",
    "        folder_type=\"raw\"\n",
    "    )\n",
    "    print(f\"\u2705 Saved company_financials.csv ({len(company_combined)} rows)\")\n",
    "\n",
    "# 2. Save grid interconnection queue data\n",
    "if \"queue_combined\" in dir() and not queue_combined.empty:\n",
    "    store_dataframes_in_dvc(\n",
    "        data=queue_combined, \n",
    "        names=\"grid_interconnection_queue\", \n",
    "        folder_type=\"raw\"\n",
    "    )\n",
    "    print(f\"\u2705 Saved grid_interconnection_queue.csv ({len(queue_combined)} rows)\")\n",
    "\n",
    "print(\"\\n\ud83c\udf89 Dataset extraction complete!\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Example 1: Fetch and store a single ticker\n",
    "ticker_name = 'MSFT'\n",
    "print(f\"\ud83d\udcc9 Fetching 1y data for {ticker_name}...\")\n",
    "msft_df = yf.Ticker(ticker_name).history(period='1y')\n",
    "\n",
    "if not msft_df.empty:\n",
    "    # We pass the single DataFrame and its name to our storage function\n",
    "    store_dataframes_in_dvc(data=msft_df, names=ticker_name, folder_type='raw')\n",
    "else:\n",
    "    print(f\"\u274c No data returned for {ticker_name}\")"
   ]
  },
{
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
     "# Example 2: Fetch and store multiple tickers simultaneously as a list",
     "tickers_list = ['GOOGL', 'AMZN']",
     "dfs = []",
     "",
     "print(f\"\\n\ud83d\udcc9 Fetching 1mo data for multiple tickers: {tickers_list}...\")",
     "for t in tickers_list:",
     "    df = yf.Ticker(t).history(period='1mo')",
     "    dfs.append(df)",
     "",
     "# Ensure we have valid data before storing",
     "valid_dfs = [df for df in dfs if not df.empty]",
     "valid_names = [t for t, df in zip(tickers_list, dfs) if not df.empty]",
     "",
     "if valid_dfs:",
     "    # We pass the list of DataFrames and the list of names to our storage function",
     "    store_dataframes_in_dvc(data=valid_dfs, names=valid_names, folder_type='raw')",
     "else:",
     "    print(\"\u274c No valid data returned for the tickers list.\")"
    ]
   },
