# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Data and Models (Use DVC for these)
data/raw/*
!data/raw/*.dvc
!data/raw/.gitignore
data/interim/*
!data/interim/*.dvc
!data/interim/.gitignore
data/processed/*
!data/processed/*.dvc
!data/processed/.gitignore
data/external/*
!data/external/*.dvc
!data/external/.gitignore
!data/**/.gitkeep
models/*
!models/*.dvc
!models/.gitignore
!models/.gitkeep

# LaTeX build files
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.pdf
!report/tex/main.pdf

